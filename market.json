{
  "schema": "skill-market.v1",
  "id": "local-skill-market",
  "title": "Local Skill Market",
  "description": "Repository-backed market for independently maintained Claude and Codex skills/plugins.",
  "repository": {
    "path": "/Users/wanglidong/Repository/skill-market",
    "defaultBranch": "main"
  },
  "adapters": ["claude", "codex"],
  "registry": {
    "index": "registry/INDEX.md",
    "skills": {
      "claude": "registry/skills/claude",
      "codex": "registry/skills/codex"
    },
    "plugins": {
      "claude": "registry/plugins/claude",
      "codex": "registry/plugins/codex"
    }
  },
  "marketSkills": {
    "claude": "market-skills/claude/skill-market",
    "codex": "market-skills/codex/skill-market"
  },
  "installTargets": {
    "skills": {
      "claude": "~/.claude/skills/<name>",
      "codex": "~/.codex/skills/<name>"
    }
  },
  "publish": {
    "mode": "pull-request",
    "branchPattern": "market/<type>/<adapter>/<name>",
    "mergeRequired": true
  }
}
